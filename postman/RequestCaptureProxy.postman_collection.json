      ]
    },
    {
      "name": "30 - Proxy Mode - Log Formatting and Truncation",
      "description": "Generates large request body to verify MAX_BODY_LOG_BYTES truncation marker.",
      "item": [
        {
          "name": "POST Large Body (truncation test)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('large_body') || pm.collectionVariables.get('large_body').length < 200000) {",
                  "  pm.collectionVariables.set('large_body', 'L'.repeat(220000));",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{large_body}}"
            },
            "url": "{{base_url}}{{request_entry_path}}/post?large=true&run={{run_id}}",
            "description": "Inspect generated log file for the truncation marker line."
          }
        }
      ]
    },
    {
      "name": "40 - IdP Mode",
      "description": "Run these only when MODE=idp and IDP settings are configured.",
      "item": [
        {
          "name": "GET Static SAML Auto-POST Response",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/saml/login?RelayState={{relay_state_dynamic}}",
            "description": "Verifies static IdP response with auto-submitting form."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'idp') {",
                  "  pm.test('Skipped (MODE=idp required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  const expectedStatus = Number(pm.environment.get('idp_expected_status') || '200');",
                  "  const fieldName = pm.environment.get('idp_form_field_name') || 'SAMLResponse';",
                  "  pm.test('Status matches expected', function () { pm.expect(pm.response.code).to.eql(expectedStatus); });",
                  "  const body = pm.response.text();",
                  "  pm.test('Response includes HTML form', function () { pm.expect(body).to.include('<form'); });",
                  "  pm.test('Response includes configured form field', function () { pm.expect(body).to.include(`name=\"${fieldName}\"`); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST RelayState Passthrough Check",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "RelayState",
                  "value": "relay-post-{{run_id}}",
                  "type": "text"
                },
                {
                  "key": "foo",
                  "value": "bar",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/saml/acs/init",
            "description": "Verifies RelayState passthrough in IdP mode when enabled."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'idp') {",
                  "  pm.test('Skipped (MODE=idp required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  const body = pm.response.text();",
                  "  pm.test('Response contains relay state from request', function () {",
                  "    pm.expect(body).to.include(`value=\"relay-post-${pm.collectionVariables.get('run_id')}\"`);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Cookie/Header Injection Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/idp/header-cookie-check",
            "description": "Verifies optional IDP_SET_COOKIE_NAME and IDP_SET_HEADER_NAME behavior when configured."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'idp') {",
                  "  pm.test('Skipped (MODE=idp required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  const cookieName = pm.environment.get('idp_cookie_name') || '';",
                  "  const headerName = pm.environment.get('idp_header_name') || '';",
                  "  if (cookieName) {",
                  "    pm.test('Configured cookie is present', function () {",
                  "      const setCookie = pm.response.headers.get('Set-Cookie') || '';",
                  "      pm.expect(setCookie).to.include(`${cookieName}=`);",
                  "    });",
                  "  }",
                  "  if (headerName) {",
                  "    pm.test('Configured header is present', function () {",
                  "      pm.expect(pm.response.headers.has(headerName)).to.eql(true);",
                  "    });",
                  "  }",
                  "  if (!cookieName && !headerName) {",
                  "    pm.test('No cookie/header assertion configured', function () { pm.expect(true).to.eql(true); });",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Custom Template Placeholder Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/idp/template-check?RelayState={{relay_state_dynamic}}",
            "description": "If IDP_BODY_TEMPLATE is configured, this verifies optional expected substring in response body."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'idp') {",
                  "  pm.test('Skipped (MODE=idp required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  const expected = pm.environment.get('idp_template_expected_text') || '';",
                  "  if (expected) {",
                  "    pm.test('Custom template expected text is present', function () {",
                  "      pm.expect(pm.response.text()).to.include(expected);",
                  "    });",
                  "  } else {",
                  "    pm.test('No template assertion configured', function () { pm.expect(true).to.eql(true); });",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
