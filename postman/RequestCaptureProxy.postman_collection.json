{
  "info": {
    "_postman_id": "a0a16598-fd8d-4db5-a3eb-8a8e1f3e6d6b",
    "name": "RequestCaptureProxy - Comprehensive Feature Suite",
    "description": "Comprehensive Postman suite for RequestCaptureProxy.\\n\\nRecommended proxy-mode upstreams for repeatable behavior:\\n- REQUEST_FORWARD_URL=http://mock-request-upstream:18081\\n- RESPONSE_FORWARD_URL=http://mock-response-upstream:18082\\n\\nRun folders based on active MODE:\\n- MODE=proxy: folders 00, 10, 20, 30\\n- MODE=idp: folder 40\\n\\nAfter requests, inspect generated files in logs/ for per-request formatting, body previews, attachment previews, and section boundaries.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = Date.now();",
          "pm.collectionVariables.set('run_id', String(now));",
          "pm.collectionVariables.set('relay_state_dynamic', `relay-${now}`);"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "run_id",
      "value": "0"
    },
    {
      "key": "relay_state_dynamic",
      "value": "relay-0"
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "description": "Verifies server liveness and reported mode.",
      "item": [
        {
          "name": "GET /healthz",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/healthz",
            "description": "Expected: 200 with JSON {status: ok, mode: proxy|idp}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('status field is ok', function () {",
                  "  pm.expect(data.status).to.eql('ok');",
                  "});",
                  "pm.test('mode is proxy or idp', function () {",
                  "  pm.expect(['proxy', 'idp']).to.include(data.mode);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "10 - Proxy Mode - Request Forwarding",
      "description": "Run these only when MODE=proxy. These exercise REQUEST_ENTRY_PATH forwarding and logging behavior.",
      "item": [
        {
          "name": "GET Request Branch (query + headers)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Debug-Run",
                "value": "{{run_id}}"
              },
              {
                "key": "X-Custom-Trace",
                "value": "request-branch"
              }
            ],
            "url": "{{base_url}}{{request_entry_path}}/get?ping=1&run={{run_id}}",
            "description": "Verifies request forwarding branch and custom header capture."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST JSON Request Branch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Debug-Run",
                "value": "{{run_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flow\": \"saml-request-branch\",\n  \"runId\": \"{{run_id}}\",\n  \"nested\": {\n    \"enabled\": true,\n    \"count\": 2\n  },\n  \"samlRequest\": \"PHNhbWxwOkF1dGhuUmVxdWVzdD5FeGFtcGxlPC9zYW1scDpBdXRoblJlcXVlc3Q+\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{request_entry_path}}/post?run={{run_id}}",
            "description": "Verifies JSON body forwarding and logging."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Form Urlencoded (SAMLRequest + RelayState)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "SAMLRequest",
                  "value": "<samlp:AuthnRequest xmlns:samlp=\"urn:oasis:names:tc:SAML:2.0:protocol\">Example</samlp:AuthnRequest>",
                  "type": "text"
                },
                {
                  "key": "RelayState",
                  "value": "relay-{{run_id}}",
                  "type": "text"
                },
                {
                  "key": "client",
                  "value": "postman-suite",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}{{request_entry_path}}/post?run={{run_id}}",
            "description": "Verifies form-encoded request capture and forwarding."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Multipart Attachment",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "metadata",
                  "value": "{\"flow\":\"multipart\",\"runId\":\"{{run_id}}\"}",
                  "type": "text"
                },
                {
                  "key": "document",
                  "type": "file",
                  "src": "{{upload_file_path}}"
                }
              ]
            },
            "url": "{{base_url}}{{request_entry_path}}/post?run={{run_id}}",
            "description": "Verifies multipart capture and attachment preview logging."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Binary Body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/octet-stream"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": "{{binary_file_path}}"
              }
            },
            "url": "{{base_url}}{{request_entry_path}}/post?binary=true&run={{run_id}}",
            "description": "Verifies binary body forwarding and base64 body logging."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Prefix Boundary Check (request_entry_path + 'evil')",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}{{request_entry_path}}evil/get?boundaryCheck={{run_id}}",
            "description": "Verifies strict boundary matching for entry paths. Inspect log FORWARDED REQUEST URL to confirm fallback path forwarding."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "20 - Proxy Mode - Response Forwarding",
      "description": "Run these only when MODE=proxy. These exercise RESPONSE_ENTRY_PATH forwarding behavior.",
      "item": [
        {
          "name": "GET Response Branch",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Custom-Trace",
                "value": "response-branch"
              }
            ],
            "url": "{{base_url}}{{response_entry_path}}/get?branch=response&run={{run_id}}",
            "description": "Verifies response-branch forwarding."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST JSON Response Branch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flow\": \"response-branch\",\n  \"runId\": \"{{run_id}}\",\n  \"note\": \"should be forwarded to RESPONSE_FORWARD_URL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{response_entry_path}}/post?run={{run_id}}",
            "description": "Verifies POST forwarding through RESPONSE_ENTRY_PATH."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
                  "if (mode !== 'proxy') {",
                  "  pm.test('Skipped (MODE=proxy required)', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Binary Response Passthrough",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}{{response_entry_path}}/image/png",
            "description": "Verifies binary response forwarding and binary log preview."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
