                  "} else {",
                  "  pm.test('Status is not 5xx', function () { pm.expect(pm.response.code).to.be.below(500); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Duplicate Set-Cookie Probe",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}{{response_entry_path}}/response-headers?Set-Cookie=a%3D1&Set-Cookie=b%3D2",
            "description": "Probes duplicate Set-Cookie forwarding using the local mock response upstream."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const mode = pm.environment.get('mode') || 'proxy';",
