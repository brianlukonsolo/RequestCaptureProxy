MODE=proxy
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080
MOCK_REQUEST_PORT=18081
MOCK_RESPONSE_PORT=18082
LOG_DIR=logs
MAX_BODY_LOG_BYTES=131072
REQUEST_TIMEOUT_SECONDS=30
PRESERVE_HOST_HEADER=false

# Local incoming paths:
REQUEST_ENTRY_PATH=/forward/request
RESPONSE_ENTRY_PATH=/forward/response

# Upstream targets:
REQUEST_FORWARD_URL=http://mock-request-upstream:18081
RESPONSE_FORWARD_URL=http://mock-response-upstream:18082

# IDP mode settings:
IDP_POST_URL=https://sp.example.com/saml/acs
IDP_SAML_RESPONSE=<Base64OrRawSamlResponseHere>
IDP_FORM_FIELD_NAME=SAMLResponse
IDP_RELAY_STATE=
IDP_PASSTHROUGH_RELAY_STATE=true
IDP_EXTRA_FORM_FIELDS={"SomeField":"SomeValue"}
IDP_SET_COOKIE_NAME=SAMLResponse
IDP_SET_HEADER_NAME=
IDP_BODY_TEMPLATE=
# IDP_BODY_TEMPLATE placeholders:
# {{SAML_RESPONSE}}, {{POST_URL}}, {{FORM_FIELD_NAME}}, {{RELAY_STATE}}, {{FORM_FIELDS_JSON}}
IDP_HTTP_STATUS=200
IDP_CONTENT_TYPE=text/html; charset=utf-8
