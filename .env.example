MODE=proxy
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080
LOG_DIR=logs
MAX_BODY_LOG_BYTES=131072
REQUEST_TIMEOUT_SECONDS=30
PRESERVE_HOST_HEADER=false

# Demo mode ports, used by docker-compose.demo.yml.
DEMO_REQUEST_LOGGER_PORT=18080
DEMO_MAX_BODY_LOG_BYTES=8192

# Local incoming paths:
REQUEST_ENTRY_PATH=/forward/request
RESPONSE_ENTRY_PATH=/forward/response
SAML_INSTANCE_SSO_PATH=/saml/instance/sso
SAML_INSTANCE_ACS_PATH=/saml/instance/acs

# Upstream targets. Leave empty for standalone UI/IdP use, or set to a real system.
# docker-compose.demo.yml supplies a demo request logger automatically.
REQUEST_FORWARD_URL=
RESPONSE_FORWARD_URL=

# Optional SAML Request/Response Sender UI presets.
# Accepts JSON object, JSON list, or comma/semicolon-delimited entries.
SAML_REQUEST_TARGETS=

# IDP mode settings:
IDP_POST_URL=https://sp.example.com/saml/acs
IDP_SAML_RESPONSE=<Base64OrRawSamlResponseHere>
IDP_FORM_FIELD_NAME=SAMLResponse
IDP_RELAY_STATE=
IDP_PASSTHROUGH_RELAY_STATE=true
IDP_EXTRA_FORM_FIELDS={"SomeField":"SomeValue"}
IDP_SET_COOKIE_NAME=SAMLResponse
IDP_SET_HEADER_NAME=
IDP_BODY_TEMPLATE=
# IDP_BODY_TEMPLATE placeholders:
# {{SAML_RESPONSE}}, {{POST_URL}}, {{FORM_FIELD_NAME}}, {{RELAY_STATE}}, {{FORM_FIELDS_JSON}}
IDP_HTTP_STATUS=200
IDP_CONTENT_TYPE=text/html; charset=utf-8
